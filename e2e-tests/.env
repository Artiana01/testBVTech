# =============================================================
# Fichier de configuration des variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# Ne jamais committer le fichier .env dans Git !
# =============================================================

# URL de base de l'application à tester
BASE_URL=https://dev.bluevaloristech.com

# ---------------------------------------------------------------
# Compte ADMIN (déjà existant sur le serveur)
# ---------------------------------------------------------------
ADMIN_EMAIL=webmaster@bluevaloris.com
ADMIN_PASSWORD=123456789Ca!

# ---------------------------------------------------------------
# Compte CLIENT pré-créé manuellement (1 seule fois sur le site)
# ⚠️  Le reCAPTCHA empêche la création automatisée via Playwright.
# → Créer ce compte sur https://dev.bluevaloristech.com/fr/signup
#   puis renseigner les identifiants ici.
# ---------------------------------------------------------------
TEST_EMAIL=e2e.client@bvtest.com
TEST_PASSWORD=ClientTest123!

# ---------------------------------------------------------------
# Flags de configuration des tests
# ---------------------------------------------------------------
# SKIP_SIGNUP_TEST=true  # Décommenter si le reCAPTCHA est activé en prod
